<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pocketstock.ledger.cma.mapper.CmaAccountMapper">

    <resultMap id="cmaAccount" type="com.pocketstock.ledger.cma.domain.CmaAccount">
        <id     property="id"            column="id"/>
        <result property="userId"        column="user_id"/>
        <result property="accountNoEnc"  column="account_no_enc"/>
        <result property="status"        column="status"/>
        <result property="openedAt"      column="opened_at"/>
        <result property="createdAt"     column="created_at"/>
        <result property="updatedAt"     column="updated_at"/>
    </resultMap>

    <select id="findByUserId" resultMap="cmaAccount">
        SELECT id, user_id, account_no_enc, status, opened_at, created_at, updated_at
        FROM cma_accounts
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.pocketstock.ledger.cma.domain.CmaAccount"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cma_accounts (user_id, account_no_enc, status, opened_at)
        VALUES (#{userId}, #{accountNoEnc}, #{status}, #{openedAt})
    </insert>

</mapper>
