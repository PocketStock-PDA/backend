<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pocketstock.ledger.trading.mapper.DepositMapper">

    <select id="findLatestKrwBalance" resultType="java.math.BigDecimal">
        SELECT balance_after
        FROM deposit_transactions
        WHERE user_id = #{userId} AND currency = 'KRW'
        ORDER BY id DESC
        LIMIT 1
    </select>

</mapper>
