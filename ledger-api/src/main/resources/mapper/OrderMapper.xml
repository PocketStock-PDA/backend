<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pocketstock.ledger.trading.mapper.OrderMapper">

    <resultMap id="order" type="com.pocketstock.ledger.trading.domain.Order">
        <id     property="id"            column="id"/>
        <result property="clientOrderId" column="client_order_id"/>
        <result property="userId"        column="user_id"/>
        <result property="accountId"     column="account_id"/>
        <result property="stockCode"     column="stock_code"/>
        <result property="exchange"      column="exchange"/>
        <result property="side"          column="side"/>
        <result property="orderType"     column="order_type"/>
        <result property="orderQuantity" column="order_quantity"/>
        <result property="price"         column="price"/>
        <result property="status"        column="status"/>
        <result property="source"        column="source"/>
        <result property="currency"      column="currency"/>
        <result property="failReason"    column="fail_reason"/>
        <result property="requestedAt"   column="requested_at"/>
        <result property="createdAt"     column="created_at"/>
        <result property="updatedAt"     column="updated_at"/>
    </resultMap>

    <sql id="cols">
        id, client_order_id, user_id, account_id, stock_code, exchange, side, order_type,
        order_quantity, price, status, source, currency, fail_reason, requested_at, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.pocketstock.ledger.trading.domain.Order"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders
            (client_order_id, user_id, account_id, stock_code, exchange, side, order_type,
             order_quantity, price, status, source, currency, fail_reason, requested_at)
        VALUES
            (#{clientOrderId}, #{userId}, #{accountId}, #{stockCode}, #{exchange}, #{side}, #{orderType},
             #{orderQuantity}, #{price}, #{status}, #{source}, #{currency}, #{failReason}, #{requestedAt})
    </insert>

    <!-- 전이 가드 ②: status=expected 일 때만 next로. 0행이면 동시성 경합으로 전이 실패. -->
    <update id="transitionFill">
        UPDATE orders
        SET status = #{next}, price = #{price}
        WHERE id = #{id} AND status = #{expected}
    </update>

    <!-- 취소 가드: 취소 가능 상태(QUEUED/PENDING)일 때만 CANCELLED. 동시 체결/이중취소 차단. -->
    <update id="cancelIfCancellable">
        UPDATE orders
        SET status = 'CANCELLED'
        WHERE id = #{id} AND user_id = #{userId}
          AND status IN ('QUEUED', 'PENDING')
    </update>

    <select id="findByUserId" resultMap="order">
        SELECT <include refid="cols"/>
        FROM orders
        WHERE user_id = #{userId}
        ORDER BY id DESC
    </select>

    <select id="findByClientOrderId" resultMap="order">
        SELECT <include refid="cols"/>
        FROM orders
        WHERE client_order_id = #{clientOrderId}
    </select>

    <select id="findByIdAndUserId" resultMap="order">
        SELECT <include refid="cols"/>
        FROM orders
        WHERE id = #{id} AND user_id = #{userId}
    </select>

    <!-- 매칭 엔진 부팅 재적재 — 거래소 집합의 지정가 PENDING 전건(국내 한정). -->
    <select id="findPendingByExchanges" resultMap="order">
        SELECT <include refid="cols"/>
        FROM orders
        WHERE status = 'PENDING' AND order_type = 'LIMIT'
          AND exchange IN
          <foreach item="ex" collection="exchanges" open="(" separator="," close=")">
              #{ex}
          </foreach>
        ORDER BY id
    </select>

</mapper>
