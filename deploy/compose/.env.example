# deploy/compose/.env.example
# 실제 값은 이 파일을 .env 로 복사해 EC2에만 둠. .env 는 절대 커밋 금지(.gitignore 추가 권장).

# --- ECR (이미지 pull 대상) ---
# 예: 123456789012.dkr.ecr.ap-northeast-2.amazonaws.com  (계정ID.dkr.ecr.<리전>.amazonaws.com)
# IMAGE_TAG 는 여기 두지 않음 — 배포 스크립트(deploy-release.sh)가 릴리스 SHA로 주입.
ECR_REGISTRY=

# --- RDS endpoint (AWS 콘솔/CLI에서 확인) ---
RDS_CORE_ENDPOINT=pocketstock-rds-core.xxxxx.ap-northeast-2.rds.amazonaws.com
RDS_LEDGER_ENDPOINT=pocketstock-rds-ledger.xxxxx.ap-northeast-2.rds.amazonaws.com

# --- DB 마스터 계정 (RDS 생성 때 정한 값) ---
CORE_DB_USERNAME=admin
CORE_DB_PASSWORD=
LEDGER_DB_USERNAME=admin
LEDGER_DB_PASSWORD=

# --- 공유 시크릿 (생성 예: openssl rand -base64 32) ---
JWT_SECRET=
ACCOUNT_CIPHER_SECRET=
# VAPID 개인키 — 부팅 필수(형식 유효해야). 생성 예: openssl rand 32 | basenc --base64url | tr -d '='
VAPID_PRIVATE_KEY=

# --- 외부 API (비우면 해당 기능만 비활성, 부팅엔 지장 없음) ---
LS_APP_KEY=
LS_APP_SECRET_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=
DART_API_KEY=
